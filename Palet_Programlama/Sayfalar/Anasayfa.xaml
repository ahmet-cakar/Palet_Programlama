                            </StackPanel>
                        </DockPanel>
                    </Border>



                </Grid>
                
                    

            </Border>
            <!-- üst menü bitiş -->


                <!-- Alt menü başlangıç -->
            <Border x:Name="AltMenu"  Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
