                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>


                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>


                    <Border x:Name="Card6"
                            Style="{StaticResource border_template}"
                            Grid.Column="1">
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam" 
                                    Background="{StaticResource button_background}" Style="{StaticResource button_template}" />

                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>


                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border x:Name="Card7"
                            Grid.Column="2" 
                            Style="{StaticResource border_template}"
>
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam" 
                                    Background="{StaticResource button_background}" Style="{StaticResource button_template}">
                                
                                
                            </Button>
                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>


                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border x:Name="Card8" Grid.Column="3" 
                            Style="{StaticResource border_template}">
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam"
                                    Background="{StaticResource button_background}" Style="{StaticResource button_template}" />

                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>


                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>



                </Grid>



            </Border>
                 <!-- Alt menü bitiş -->

        </Grid>

 

        </Grid>
    
    
</Page>
