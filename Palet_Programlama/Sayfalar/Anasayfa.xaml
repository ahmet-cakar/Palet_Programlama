<Page x:Class="Palet_Programlama.Sayfalar.Anasayfa"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Palet_Programlama.Sayfalar"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="Anasayfa">


    <Grid>
        <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <Image Source="pack://application:,,,/Resimler/background.png"
            Grid.RowSpan="5"
            Grid.ColumnSpan="5"
            />

        <Grid  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
            <!-- üst menü başlangıç -->
            <Border x:Name="UstMenu"  Grid.Row="0">
                    <!-- Menü üst 4lü -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                    <!-- Card yapısı -->
                    <Border x:Name="Card1" Grid.Column="0" Margin="5" Background="#d4d4d4" CornerRadius="30" Padding="10" BorderBrush="Gray" BorderThickness="1">
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam" DockPanel.Dock="Bottom" HorizontalAlignment="Right" Margin="0,10,5,0" Width="75" Height="50" Background="{StaticResource button_background}" Style="{StaticResource button_template}" />

                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                <TextBlock  FontSize="16" FontWeight="Bold" Foreground="Black" Text="FMCG" />
                                <TextBlock  FontSize="16" FontWeight="Bold" Foreground="Black" Text="Projeleri" />
                            </StackPanel>
                           

                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                        
                        
                    <Border x:Name="Card2" Grid.Column="1" Margin="5" Background="#d4d4d4" CornerRadius="30" Padding="10" BorderBrush="Gray" BorderThickness="1">
