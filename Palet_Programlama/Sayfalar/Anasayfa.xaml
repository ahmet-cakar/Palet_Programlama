<Page x:Class="Palet_Programlama.Sayfalar.Anasayfa"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Palet_Programlama.Sayfalar"
      mc:Ignorable="d" 
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="Anasayfa">


    <Grid>
        <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <Image Source="pack://application:,,,/Resimler/background.png"
            Grid.RowSpan="5"
            Grid.ColumnSpan="5"
            />

        <Grid  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
            <!-- üst menü başlangıç -->
            <Border x:Name="UstMenu"  Grid.Row="0">
                    <!-- Menü üst 4lü -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                    <!-- Card yapısı -->
                    <Border x:Name="Card1" 
                            Grid.Column="0" 
                            Style="{StaticResource border_template}">
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam" 
                                    Background="{StaticResource button_background}" Style="{StaticResource button_template}" />

                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom"
                                        VerticalAlignment="Bottom" 
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,-50">
                                <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>
                           

                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel 
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>
                        
                        
                    <Border x:Name="Card2"
                            Grid.Column="1" 
                             Style="{StaticResource border_template}"
>
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam"
                                     Background="{StaticResource button_background}" Style="{StaticResource button_template}" />

                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>


                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border x:Name="Card3" 
                            Grid.Column="2" 
                            Style="{StaticResource border_template}"
>
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam" 
                                     Background="{StaticResource button_background}" Style="{StaticResource button_template}" />

                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>


                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <Border x:Name="Card4" Grid.Column="3"
                           Style="{StaticResource border_template}"
>
                        <DockPanel>
                            <!-- Sağ altta buton -->
                            <Button Content="Devam"
                                     Background="{StaticResource button_background}" Style="{StaticResource button_template}" />

                            <!-- Sol alttaki açıklama -->
                            <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,0,0,-50">
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="FMCG" />
                                 <TextBlock  Style="{StaticResource textblock_template}" Text="Projeleri" />
                            </StackPanel>


                            <!-- Ortadaki icon (örnek bir icon) -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image  Source="pack://application:,,,/Resimler/settings.png" Width="80" Height="80" Margin="0,10" />
                            </StackPanel>
                        </DockPanel>
                    </Border>



                </Grid>
                
                    

            </Border>
            <!-- üst menü bitiş -->


                <!-- Alt menü başlangıç -->
            <Border x:Name="AltMenu"  Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card yapısı -->
                    <Border x:Name="Card5" Grid.Column="0" 
                            Style="{StaticResource border_template}">
