<Page x:Class="Palet_Programlama.Sayfalar.DizilimYap"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Palet_Programlama.Sayfalar"
      xmlns:sınıflar="clr-namespace:Palet_Programlama.Sınıflar"
      mc:Ignorable="d"
      d:DesignHeight="868" d:DesignWidth="1809.135"
      Title="Dizilim_Yap">

  <Page.Resources>
    <sınıflar:LanguageConverter x:Key="LanguageConverter" />
  </Page.Resources>

  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,0,10">
      <Border VerticalAlignment="Center">
        <local:UstMenu Margin="0,5,0,0"/>
      </Border>
    </Grid>

    <!-- Üst bilgi alanı -->
    <Grid Grid.Row="1" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.14*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Aynalama ve X/Y -->
      <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    Padding="18,10"
                    CornerRadius="15"
                    Background="#191919">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="24"
                                   Text="{Binding Source='DizilimYap.txtAynalama',Converter={StaticResource LanguageConverter}}"/>
            <CheckBox Grid.Column="1"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource checkbox_siyah_aynalama}"/>
          </Grid>

          <Grid Grid.Column="1" Margin="0,0,10,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="24"
                                   Text="{Binding Source='DizilimYap.txtXeksen',Converter={StaticResource LanguageConverter}}"/>
            <CheckBox Grid.Column="1"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource checkbox_siyah_aynalama}"/>
          </Grid>

          <Grid Grid.Column="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Foreground="White"
                                   FontSize="24"
                                   Text="{Binding Source='DizilimYap.txtYeksen',Converter={StaticResource LanguageConverter}}"/>
            <CheckBox Grid.Column="1"
                                  Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  Style="{StaticResource checkbox_siyah_aynalama}"/>
          </Grid>
        </Grid>
      </Border>

      <!-- Ürün / Palet özellikleri -->
      <Border Grid.Column="1"
                    Margin="8,0,0,0"
                    Padding="18,10"
                    CornerRadius="15"
                    Background="#191919">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                                   FontSize="20"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="{Binding Source='DizilimYap.urunozellik',Converter={StaticResource LanguageConverter}}"/>

            <TextBlock Grid.Column="1"
                                   Margin="10,0,0,0"
                                   FontSize="20"
                                   Foreground="White"
                                   Name="txtUrunOzellikleri"
                                   Text=""
                                   TextWrapping="Wrap"/>
          </Grid>

          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="110*"/>
              <ColumnDefinition Width="399*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                                   FontSize="20"
                                   Foreground="White"
                                   FontWeight="SemiBold"
                                   Text="{Binding Source='DizilimYap.paletozellik',Converter={StaticResource LanguageConverter}}" Margin="0,0,10,0"/>

            <TextBlock Grid.Column="1"
                                   x:Name="txtPaletOzellikleri"
                                   Margin="2,0,0,0"
                                   FontSize="20"
                                   Foreground="White"
                                   Text=""
                                   TextWrapping="Wrap" Grid.ColumnSpan="2"/>
          </Grid>
        </Grid>
      </Border>
    </Grid>

    <!-- Ana orta alan -->
    <Grid Grid.Row="2" Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="4.5*"/>
        <ColumnDefinition Width="3.5*"/>
        <ColumnDefinition Width="90"/>
      </Grid.ColumnDefinitions>

      <!-- Sol taraf -->
      <Grid Grid.Column="0" Margin="0,0,10,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Kat kopyala -->
        <Border Grid.Row="0"
                        Margin="0,0,0,10"
                        Padding="18,18,18,14"
                        CornerRadius="15"
                        Background="#191919">
          <StackPanel>
            <TextBlock Foreground="White"
                                   FontSize="28"
                                   Margin="0,0,0,14"
                                   Text="{Binding Source='DizilimYap.txtKatKopyala',Converter={StaticResource LanguageConverter}}"/>

            <WrapPanel VerticalAlignment="Center">
              <TextBlock Margin="0,0,14,0"
                                       FontSize="24"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       Text="{Binding Source='DizilimYap.kopyala',Converter={StaticResource LanguageConverter}}"/>

              <Button Width="25"  
                                    Height="25"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource transparan_button}">
                <StackPanel MouseDown="BtnKopyalaArti_MouseDown"  Orientation="Horizontal" HorizontalAlignment="Center">
                  <Image Source="pack://application:,,,/Resimler/DizilimYap/arti.png"/>
                </StackPanel>
              </Button>

              <TextBlock Width="35"   Name="txtKopyalaValue"
                                       VerticalAlignment="Center"
                                       FontSize="24"
                                       Foreground="White"
                                       Text="1"/>

              <Button Width="30"
                                    Height="25"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource transparan_button}">
                <StackPanel MouseDown="BtnKopyalaEksi_MouseDown" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Image Source="pack://application:,,,/Resimler/DizilimYap/eksi.png"/>
                </StackPanel>
              </Button>

              <TextBlock Margin="0,0,14,0"
                                       FontSize="24"
                                       VerticalAlignment="Center"
                                       Foreground="White"
                                       Text="{Binding Source='DizilimYap.yapistir',Converter={StaticResource LanguageConverter}}"/>

              <Button Width="30"
                                    Height="25"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource transparan_button}">
                <StackPanel MouseDown="BtnYapistirArti_MouseDown" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Image Source="pack://application:,,,/Resimler/DizilimYap/arti.png"/>
                </StackPanel>
              </Button>

              <TextBlock Width="35" Name="txtYapisValue"
                                       VerticalAlignment="Center"
                                       FontSize="24"
                                       Foreground="White"
                                       Text="1"/>

              <Button Width="30" 
                                    Height="25"
                                    Margin="0,0,20,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource transparan_button}">
                <StackPanel MouseDown="BtnYapistirEksi_MouseDown" Orientation="Horizontal" HorizontalAlignment="Center">
                  <Image Source="pack://application:,,,/Resimler/DizilimYap/eksi.png"/>
                </StackPanel>
              </Button>

              <Button MouseDown="BtnKatKopyala_MouseDown" Margin="60,0,0,0"  Content="{Binding Source='DizilimYap.kopyalabtn',Converter={StaticResource LanguageConverter}}"
                                    Width="150"
                                    Background="{StaticResource button_background}"
                                    Style="{StaticResource button_template}" />
            </WrapPanel>
          </StackPanel>
        </Border>

        <!-- Pozisyon seçimi -->
        <Border Grid.Row="1"
                        Margin="0,0,0,10"
                        Padding="18"
                        CornerRadius="20"
                        Background="#191919">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.2*"/>
              <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
              <TextBlock Foreground="White"
                                       FontSize="28"
                                       Margin="0,0,0,16"
                                       Text="{Binding Source='DizilimYap.txtPozisyonSecimi',Converter={StaticResource LanguageConverter}}"/>

              <StackPanel Margin="0,20,0,0"
                                        VerticalAlignment="Top"
                                        Orientation="Horizontal">
                <StackPanel Width="20" Height="20" VerticalAlignment="Top">
                  <Image Source="pack://application:,,,/Resimler/DizilimYap/info-icon.png"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Margin="8,0,0,0">
                  <TextBlock Text="{Binding Source='DizilimYap.txtYazi1',Converter={StaticResource LanguageConverter}}"
                                               Foreground="White"
                                               FontSize="18"
                                               TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Source='DizilimYap.txtYazi2',Converter={StaticResource LanguageConverter}}"
                                               Foreground="White"
                                               FontSize="18"
                                               TextWrapping="Wrap"/>
                  <TextBlock Text="{Binding Source='DizilimYap.txtYazi3',Converter={StaticResource LanguageConverter}}"
                                               Foreground="White"
                                               FontSize="18"
                                               TextWrapping="Wrap"/>
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="{Binding Source='DizilimYap.txtDikey',Converter={StaticResource LanguageConverter}}"
                                           Width="140"
                                           Foreground="White"
                                           FontSize="20"
                                           TextAlignment="Center"/>

                <TextBlock Text="{Binding Source='DizilimYap.txtYatay',Converter={StaticResource LanguageConverter}}"
                                           Margin="20,0,0,0"
                                           Width="140"
                                           Foreground="White"
                                           FontSize="20"
                                           TextAlignment="Center"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,16,0,0">
                <Rectangle Name="dikeyKutu"
                                           Width="100"
                                           Height="150"
                                           Margin="10,0,20,0"
                                           MouseDown="dikeyKutu_MouseDown"
                                           Stroke="Transparent"
                                           StrokeThickness="0">
                  <Rectangle.Fill>
                    <ImageBrush ImageSource="/Resimler/DizilimYap/dikey_kutu.png"/>
                  </Rectangle.Fill>
                </Rectangle>

                <Rectangle Name="yatayKutu"
                                           Width="150"
                                           Height="100"
                                           Margin="10,25,0,0"
                                           MouseDown="yatayKutu_MouseDown"
                                           Stroke="Transparent"
                                           StrokeThickness="0">
                  <Rectangle.Fill>
                    <ImageBrush ImageSource="/Resimler/DizilimYap/yatay_kutu.png"/>
                  </Rectangle.Fill>
                </Rectangle>
              </StackPanel>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Alt sol -->
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.4*"/>
            <ColumnDefinition Width="1*"/>
          </Grid.ColumnDefinitions>

          <!-- MOD -->
          <Border Grid.Column="0"
                            Margin="0,0,10,0"
                            Padding="18"
                            CornerRadius="20"
                            Background="#191919">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock Margin="0,10,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="White"
                                           FontSize="24"
                                           Text="{Binding Source='DizilimYap.txtCokluEkleMod',Converter={StaticResource LanguageConverter}}"/>

                <TextBlock VerticalAlignment="Center"
                                           Margin="0,30,0,0"
                                           Foreground="White"
                                           FontSize="24"
                                           Text="{Binding Source='DizilimYap.txtHizalamaMod',Converter={StaticResource LanguageConverter}}"/>

                <TextBlock VerticalAlignment="Center"
                                           Margin="0,30,0,0"
                                           Foreground="White"
                                           FontSize="24"
                                           Text="{Binding Source='DizilimYap.txtPaletTasimaMod',Converter={StaticResource LanguageConverter}}"/>

                <TextBlock VerticalAlignment="Center"
                                           Margin="0,30,0,0"
                                           Foreground="White"
                                           FontSize="24"
                                           Text="{Binding Source='DizilimYap.txtKatTasimaMod',Converter={StaticResource LanguageConverter}}"/>
              </StackPanel>

              <StackPanel Grid.Column="1" Orientation="Vertical" Margin="20,6,0,0">
                <CheckBox Margin="0,12,0,0" Style="{StaticResource checkbox_siyah_mod}" />
                <CheckBox Margin="0,30,0,0" Style="{StaticResource checkbox_siyah_mod}" />
                <CheckBox Margin="0,30,0,0" Style="{StaticResource checkbox_siyah_mod}" />
                <CheckBox Margin="0,30,0,0" Style="{StaticResource checkbox_siyah_mod}" />
              </StackPanel>
            </Grid>
          </Border>

          <!-- Sağ mini kontrol -->
          <Grid Grid.Column="1">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- mm alanı -->
            <Border Grid.Row="0"
                                Margin="0,0,0,10"
                                Padding="10"
                                CornerRadius="20"
                                Background="#191919">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                                        VerticalAlignment="Center"
                                        Width="30"
                                        Height="25"
                                        Style="{StaticResource transparan_button}">
                  <StackPanel MouseDown="BtnHareketMiktariArti_MouseDown" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resimler/DizilimYap/arti.png"/>
                  </StackPanel>
                </Button>

                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Grid.Column="1">
                  <TextBox Width="55" Name="txtHareketMiktari"
                                             FontSize="25"
                                             VerticalAlignment="Center"
                                             Foreground="White"
                                             Text="10"
                                             TextAlignment="Center"
                                             Background="Transparent"
                                             BorderThickness="0" />

                  <TextBlock Margin="5,0,0,0"
                                               FontSize="20"
                                               VerticalAlignment="Center"
                                               Foreground="White"
                                               Text="mm"/>
                </StackPanel>

                <Button Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Width="30"
                                        Height="25"
                                        Style="{StaticResource transparan_button}">
                  <StackPanel MouseDown="BtnHareketMiktariEksi_MouseDown" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resimler/DizilimYap/eksi.png"/>
                  </StackPanel>
                </Button>
              </Grid>
            </Border>

            <!-- yön butonları -->
            <Border Grid.Row="1"
                                CornerRadius="20"
                                Background="#191919">
              <Viewbox Stretch="Uniform">
                <Grid Width="240" Height="220" Margin="20">
                  <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                  </Grid.ColumnDefinitions>

                  <Button Grid.Row="0" Grid.Column="1" Width="60" Height="60" Style="{StaticResource transparan_button}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <Image Source="pack://application:,,,/Resimler/DizilimYap/yukari_ok.png"/>
                    </StackPanel>
                  </Button>

                  <Button Grid.Row="1" Grid.Column="0" Width="60" Height="50" Style="{StaticResource transparan_button}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <Image Source="pack://application:,,,/Resimler/DizilimYap/sola_ok.png"/>
                    </StackPanel>
                  </Button>

                  <Button Grid.Row="1" Grid.Column="2" Width="60" Height="50" Style="{StaticResource transparan_button}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <Image Source="pack://application:,,,/Resimler/DizilimYap/saga_ok.png"/>
                    </StackPanel>
                  </Button>

                  <Button Grid.Row="2" Grid.Column="1" Width="60" Height="60" Style="{StaticResource transparan_button}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                      <Image Source="pack://application:,,,/Resimler/DizilimYap/asagi_ok.png"/>
                    </StackPanel>
                  </Button>
                </Grid>
              </Viewbox>
            </Border>
          </Grid>
        </Grid>
      </Grid>

      <!-- Palet alanı -->
      <Border Grid.Column="1"
                    Margin="0,0,10,0"
                    Padding="14"
                    CornerRadius="20"
                    Background="#191919">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2">
            <StackPanel HorizontalAlignment="Left">
              <Image Margin="20,10,0,0"
                                   MaxHeight="160"
                                   MaxWidth="160"
                                   Source="pack://application:,,,/Resimler/DizilimYap/referans_eksenler.png"/>
            </StackPanel>
          </Grid>

          <!-- Responsive canvas -->
          <Viewbox Grid.Column="1"
                             Grid.Row="1"
                             Stretch="Uniform"
                             StretchDirection="DownOnly"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
            <Canvas Name="myCanvas"
                                Width="600"
                                Height="400"
                                MouseLeftButtonDown="myCanvas_MouseLeftButtonDown">
              <Canvas.Background>
                <ImageBrush ImageSource="pack://application:,,,/Resimler/DizilimYap/palet.png"/>
              </Canvas.Background>

            </Canvas>
          </Viewbox>
        </Grid>
      </Border>

      <!-- Kat paneli -->
      <Border Grid.Column="2"
                    Margin="8,0,0,0"
                    Padding="10"
                    CornerRadius="20"
                    Background="#191919">
        <Grid Margin="0,20,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <TextBlock Grid.Row="0"
                               Margin="0,10,0,20"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Foreground="White"
                               FontSize="28"
                               Text="{Binding Source='DizilimYap.txtKat',Converter={StaticResource LanguageConverter}}"/>

          <StackPanel Grid.Row="1" Orientation="Vertical" VerticalAlignment="Center">
            <Button Margin="0,20,0,0" Style="{StaticResource transparan_button}" x:Name="AnasayfaBtn">
              <StackPanel>
                <Image x:Name="btnKatArti"
                                       MouseDown="btnKatArti_MouseDown"
                                       MaxHeight="50"
                                       MaxWidth="50"
                                       Source="pack://application:,,,/Resimler/DizilimYap/yukari_icon.png"/>
              </StackPanel>
            </Button>

            <TextBlock x:Name="txtKat"
                                   Margin="0,20,0,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="White"
                                   FontSize="30"
                                   Text="1"/>

            <Button Margin="0,20,0,0" Style="{StaticResource transparan_button}">
              <StackPanel>
                <Image x:Name="btnKatEksi"
                                       MouseDown="btnKatEksi_MouseDown"
                                       MaxHeight="50"
                                       MaxWidth="50"
                                       Source="pack://application:,,,/Resimler/DizilimYap/asagi_icon.png"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- Footer -->
    <Grid Grid.Row="3">
      <Border CornerRadius="20"
                    Margin="0,0,0,0"
                    Background="Transparent">
        <WrapPanel>
          <Button FontSize="24" Click="Dizilimi_Kaydet_Click"
                            Content="{Binding Source='DizilimYap.btnDizilimiKaydet',Converter={StaticResource LanguageConverter}}"
                            Width="240"
                            Margin="0,0,10,10"
                            Background="{StaticResource button_background_green}"
                            Style="{StaticResource button_template}" />

          <Button FontSize="24"  Click="Button_Click"
                            Content="{Binding Source='DizilimYap.btnKatTemizle',Converter={StaticResource LanguageConverter}}"
                            Width="240"
                            Margin="0,0,10,10"
                            Background="{StaticResource button_background}"
                            Style="{StaticResource button_template}" />

          <Button FontSize="24" Click="Button_Click_1"
                            Content="{Binding Source='DizilimYap.btnPaletTemizle',Converter={StaticResource LanguageConverter}}"
                            Width="240"
                            Margin="0,0,10,10"
                            Background="{StaticResource button_background_black}"
                            Style="{StaticResource button_template}" />

          <Button FontSize="24" Click="Button_Click_2"
                            Content="{Binding Source='DizilimYap.btnSeciliUrunuSil',Converter={StaticResource LanguageConverter}}"
                            Width="240"
                            Margin="0,0,10,10"
                            Background="{StaticResource button_background_gray}"
                            Style="{StaticResource button_template}" />
        </WrapPanel>
      </Border>
    </Grid>
  </Grid>
</Page>