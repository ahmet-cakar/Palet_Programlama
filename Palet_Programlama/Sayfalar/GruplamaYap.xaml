<Page x:Class="Palet_Programlama.Sayfalar.GruplamaYap"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Palet_Programlama.Sayfalar"
      xmlns:sınıflar="clr-namespace:Palet_Programlama.Sınıflar"
      mc:Ignorable="d" 
      
      d:DesignHeight="768" d:DesignWidth="1366"
      Title="GruplamaYap">
  <Page.Resources>
    <sınıflar:LanguageConverter  x:Key="LanguageConverter" />
  </Page.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="7*"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>
    <!-- Header item control başlangıç -->
    <Grid Grid.Row="0">
      <Border VerticalAlignment="Center">
        <local:UstMenu Margin="0,5,0,0"/>
      </Border>
    </Grid>
    <!-- Header item control bitiş -->

    <Grid Grid.Row="1" >
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>
        <!-- Ürün En-Boy alanı başlangıç -->
        <Border CornerRadius="15" Grid.Column="0" Margin="50,20,10,0"  Background="#191919">

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition  Width="*"/>
              <ColumnDefinition Width="5*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"  HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock 
                    Foreground="White"
                    FontSize="28"
                    Text="{Binding Source='GruplamaYap.txtPalet',Converter={StaticResource LanguageConverter}}"/>
            </Grid>
            <Grid Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center">
              <TextBlock 
               x:Name="txtPaletOzellikleri" 
               Foreground="White"
               FontWeight="Thin"
               FontSize="26"
               Text="EuroPalet - 280 mm X 300 mm X 600 mm"/>  
            </Grid>


          </Grid>
        



        </Border>
        <!-- Ürün En-Bot alanı bitiş -->

        <!-- Gruplandırma alanı başlangıç -->

        <Border Grid.Column="1" CornerRadius="15"  Margin="0,20,40,0"  Background="#191919">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>
            <StackPanel VerticalAlignment="Center" 
                                    Grid.Column="0">

              <TextBlock  VerticalAlignment="Center" 
                                    HorizontalAlignment="Center"
                          Foreground="White"
                          FontSize="28"
                          Text="{Binding Source='GruplamaYap.txtGruplandirma',Converter={StaticResource LanguageConverter}}"></TextBlock>
            </StackPanel>
            <StackPanel Margin="30,0,0,0" Grid.Column="1" Orientation="Horizontal">
              <Button x:Name="BtnGruplandirmaEksi" Margin="0,0,80,0" Style="{StaticResource transparan_button}" Click="BtnGruplandirmaEksi_Click">
                <StackPanel>
                  <Image 
                                       MaxHeight="60"
                                       MaxWidth="60"
                                       Source="pack://application:,,,/Resimler/UserControlUstMenu/geri_icon.png"/>
                </StackPanel>
              </Button>
              <TextBlock x:Name="txtGrupValue"  VerticalAlignment="Center"
                                        Margin="0,0,80,0"
                                        TextAlignment="Center"
                                     Foreground="White"
                                     FontSize="34"
                                     Text="1" Width="57"/>
              <Button x:Name="BtnGruplandirmaArti" Style="{StaticResource transparan_button}" Click="BtnGruplandirmaArti_Click" >
                <StackPanel>
                  <Image 
                                MaxHeight="60"
                                MaxWidth="60"
                                Source="pack://application:,,,/Resimler/UserControlUstMenu/ileri_icon.png"/>
                </StackPanel>
              </Button>

            </StackPanel>
          </Grid>
        </Border>
        <!-- Gruplandırma  alanı bitiş -->

      </Grid>

    </Grid>


    <Grid Grid.Row="2">



      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="8*"/>
        <ColumnDefinition Width="7*"/>
        <ColumnDefinition Width="*"/>


      </Grid.ColumnDefinitions>




      <Border>
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>

          </Grid.RowDefinitions>
          <!-- Ürün Dizilim seçim alanı başlangıç -->
          <Border Grid.Row="0" Margin="50,10,10,10"
                         CornerRadius="15" 
                         Background="#191919"
                          >
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>

              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>

              </Grid.RowDefinitions>
              <TextBlock Margin="40,0,0,0"
                                       VerticalAlignment="Center"
                                       Grid.Column="0" Grid.Row="0"
                                       Foreground="White"
                                       FontSize="26" Text="{Binding Source='GruplamaYap.txtUrunSecimi',Converter={StaticResource LanguageConverter}}"></TextBlock>
              <TextBlock Margin="40,0,0,0"
                                   VerticalAlignment="Top"
                                   Grid.Column="0" Grid.Row="1"
                                   Foreground="White"
                                   FontSize="26" Text="{Binding Source='GruplamaYap.txtDizilimSecimi',Converter={StaticResource LanguageConverter}}"></TextBlock>

              <ComboBox x:Name="CboxDizilimListesi" Margin="0,0,30,0" Grid.Column="1" Grid.Row="1"
                               
                                FontSize="20"
                                Style="{DynamicResource theComboBox}"
                                Background="#d4d4d4"
                                HorizontalContentAlignment="Left"
                                VerticalAlignment="Top"
                                Foreground="#575757"
                                MinWidth="100"
                                Height="45"
                                       
                                MaxWidth="500"
                                SelectedIndex="0"
                                ItemContainerStyle="{DynamicResource theComboBoxItem}" SelectionChanged="CboxDizilimListesi_SelectionChanged"
>
              
              </ComboBox>

              <ComboBox x:Name="CboxUrunListesi"  Grid.Column="1" Grid.Row="0"
                                Margin="0,0,30,0" 
                                FontSize="20"
                                Style="{DynamicResource theComboBox}"
                                Background="#d4d4d4"
                                Foreground="#575757"
                                SelectedIndex="0"
                                HorizontalContentAlignment="Left"
                                VerticalAlignment="Center"
                                MinWidth="100"
                                MaxWidth="500"
                                Height="45"
                                

                                ItemContainerStyle="{DynamicResource theComboBoxItem}" SelectionChanged="CboxUrunListesi_SelectionChanged"
>
    
              </ComboBox>
            </Grid>
          </Border>
          <!-- Gruplama seçimi alanı başlangıç -->
          <Border  Grid.Column="0"  Margin="50,10,10,10" Grid.Row="1"
                             CornerRadius="15" 
                        Background="#191919">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Margin="0,0,0,15"
               Foreground="#F3F4F6"
               HorizontalAlignment="Center"
               FontSize="26"
               FontWeight="SemiBold"
               Text="{Binding Source='GruplamaYap.txtGruplamaSecimi',Converter={StaticResource LanguageConverter}}"/>

                <ListBox Background="Transparent"
             BorderThickness="0"
             Height="400"
             Margin="35,0,15,0"
             HorizontalContentAlignment="Stretch"
             ScrollViewer.VerticalScrollBarVisibility="Auto">

                  <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel />
                    </ItemsPanelTemplate>
                  </ListBox.ItemsPanel>

                  <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                      <Setter Property="Margin" Value="0,0,0,12"/>
                      <Setter Property="Padding" Value="0"/>
                      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                      <Setter Property="Cursor" Value="Hand"/>
                      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="ItemBorder"
                                    Background="#222222"
                                    BorderBrush="#303030"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="18,14">
                              <ContentPresenter HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2A2A2A"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#3A3A3A"/>
                              </Trigger>

                              <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#343434"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#4A4A4A"/>
                              </Trigger>

                              <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.6"/>
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </ListBox.ItemContainerStyle>

                  <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Foreground="#E5E7EB"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="{Binding Source='GruplamaYap.txtKatNo',Converter={StaticResource LanguageConverter}}"/>

                      <TextBlock Margin="6,0,0,0"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="1"/>

                      <Border Width="1"
                Height="22"
                Margin="16,2"
                Background="#4B5563"/>

                      <TextBlock Foreground="#E5E7EB"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="{Binding Source='GruplamaYap.txtGrupNo',Converter={StaticResource LanguageConverter}}"/>

                      <TextBlock Margin="6,0,0,0"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="1"/>
                    </StackPanel>
                  </ListBoxItem>

                  <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Foreground="#E5E7EB"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="{Binding Source='GruplamaYap.txtKatNo',Converter={StaticResource LanguageConverter}}"/>

                      <TextBlock Margin="6,0,0,0"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="1"/>

                      <Border Width="1"
                Height="22"
                Margin="16,2"
                Background="#4B5563"/>

                      <TextBlock Foreground="#E5E7EB"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="{Binding Source='GruplamaYap.txtGrupNo',Converter={StaticResource LanguageConverter}}"/>

                      <TextBlock Margin="6,0,0,0"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="1"/>
                    </StackPanel>
                  </ListBoxItem>

                  <ListBoxItem>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Foreground="#E5E7EB"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="{Binding Source='GruplamaYap.txtKatNo',Converter={StaticResource LanguageConverter}}"/>

                      <TextBlock Margin="6,0,0,0"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="1"/>

                      <Border Width="1"
                Height="22"
                Margin="16,2"
                Background="#4B5563"/>

                      <TextBlock Foreground="#E5E7EB"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Text="{Binding Source='GruplamaYap.txtGrupNo',Converter={StaticResource LanguageConverter}}"/>

                      <TextBlock Margin="6,0,0,0"
                   Foreground="White"
                   FontSize="20"
                   FontWeight="Bold"
                   Text="1"/>
                    </StackPanel>
                  </ListBoxItem>
                
                
                    
                
                </ListBox>
              </StackPanel>

              <StackPanel
                                Grid.Column="1"
                                Margin="0,20,0,10"
                                Orientation="Vertical">
                <Button FontSize="24" 
                                HorizontalAlignment="Center"
                                Content="{Binding Source='GruplamaYap.btnAyarlar',Converter={StaticResource LanguageConverter}}" Width="200"  Margin="10,0,0,0"
                                Background="{StaticResource button_background}" 
                                Style="{StaticResource button_template}" />


                <Button FontSize="24" 
                                 HorizontalAlignment="Center"
                                 Content="{Binding Source='GruplamaYap.btnAyir',Converter={StaticResource LanguageConverter}}" Width="200"  Margin="10,250,0,0"
                                 Background="{StaticResource button_background}" 
                                 Style="{StaticResource button_template}" />

                <Button FontSize="24" 
                                  HorizontalAlignment="Center"
                                  Content="{Binding Source='GruplamaYap.btnBirlestir',Converter={StaticResource LanguageConverter}}" Width="200"  Margin="10,10,0,0"
                                  Background="{StaticResource button_background}" 
                                  Style="{StaticResource button_template}" />
              </StackPanel>
           
           </Grid>


          </Border>
          <!-- Gruplama seçimi alanı bitiş -->


          <Grid Grid.Row="2">
            <Border Grid.Row="0" Margin="50,10,10,10">

            </Border>
          </Grid>

        </Grid>
      </Border>

      <!--Urun dizme alanı başlangıç-->
      <Border CornerRadius="20" Margin="5,10,35,10"  Grid.Column="1"   Background="#191919">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6*"/>

          </Grid.RowDefinitions>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="8*"/>

          </Grid.ColumnDefinitions>
          <Grid Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2" >
            <StackPanel HorizontalAlignment="Left"  >
              <Image  Margin="40,25,0,0"
                           MaxHeight="250"
                           MaxWidth="250"
                           Source="pack://application:,,,/Resimler/DizilimYap/referans_eksenler.png"/>
            </StackPanel>
          </Grid>

          <Border Grid.Column="1" Grid.Row="1">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"  >

              <Canvas Name="myCanvas"
                                Width="600"
                                Height="400"
                                >
                <Canvas.Background>
                  <ImageBrush ImageSource="pack://application:,,,/Resimler/DizilimYap/palet.png"/>
                </Canvas.Background>
              </Canvas>

            </StackPanel>
          </Border>

        </Grid>
      </Border>
      <!--Urun dizme alanı başlangıç-->

      <!--Kat arttırma azaltma alanı başlangıç-->
      <Border CornerRadius="20" Margin="-20,10,40,10" Background="#191919"  Grid.Column="2">
        <Grid Margin="0,40,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>

          </Grid.RowDefinitions>

          <StackPanel Grid.Row="0">

            <TextBlock Margin="0,50,0,0" VerticalAlignment="Center" HorizontalAlignment="Center"
                      Foreground="White"
                      FontSize="30"
                      Text="{Binding Source='DizilimYap.txtKat',Converter={StaticResource LanguageConverter}}"></TextBlock>
          </StackPanel>

          <StackPanel Grid.Row="1" Orientation="Vertical">
            <Button x:Name="BtnKatArti" Margin="0,80,0,0" Style="{StaticResource transparan_button}"  Click="BtnKatArti_Click">
              <StackPanel>
                <Image 
                               MaxHeight="50"
                               MaxWidth="50"
                               Source="pack://application:,,,/Resimler/DizilimYap/yukari_icon.png"/>
              </StackPanel>
            </Button>
            <TextBlock x:Name="txtKatValue" TextAlignment="Center" Margin="0,20,0,0" HorizontalAlignment="Center"
                     Foreground="White"
                     FontSize="30"
                     Text="1" Width="46"/>
            <Button x:Name="BtnKatEksi" Margin="0,20,0,0" Style="{StaticResource transparan_button}" Click="BtnKatEksi_Click" >
              <StackPanel>
                <Image 
                        MaxHeight="50"
                        MaxWidth="50"
                        Source="pack://application:,,,/Resimler/DizilimYap/asagi_icon.png"/>
              </StackPanel>
            </Button>

          </StackPanel>
        </Grid>
      </Border>
      <!--Kat arttırma azaltma alanı bitiş-->
    </Grid>

    <!--Alt buttonlar Footer başlangıç-->
    <Grid Grid.Row="3" >
      <Border CornerRadius="20"  Margin="50,0,300,10" Background="Transparent">
        <StackPanel Orientation="Horizontal">
          <Button FontSize="24"  Content="{Binding Source='GruplamaYap.btnKaydet',Converter={StaticResource LanguageConverter}}" Width="240" 
                             Background="{StaticResource button_background_green}" Style="{StaticResource button_template}" />
          <Button FontSize="24"   Content="{Binding Source='GruplamaYap.btnGruplariTemizle',Converter={StaticResource LanguageConverter}}" Width="240"  Margin="10,0,0,0"
         Background="{StaticResource button_background}" Style="{StaticResource button_template}" />
          <Button FontSize="24"   Content="{Binding Source='GruplamaYap.btnManuelDiz',Converter={StaticResource LanguageConverter}}" Width="240" Margin="10,0,0,0"
         Background="{StaticResource button_background}" Style="{StaticResource button_template}" />
          <Button FontSize="24"   Content="{Binding Source='GruplamaYap.btnDizilimListesi',Converter={StaticResource LanguageConverter}}" Width="240" Margin="10,0,0,0"
         Background="{StaticResource button_background}" Style="{StaticResource button_template}" />
        </StackPanel>
      </Border>
    </Grid>
    <!--Alt buttonlar Footer bitiş-->

  </Grid>
</Page>
