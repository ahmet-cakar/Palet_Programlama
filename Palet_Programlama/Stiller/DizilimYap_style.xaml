<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="checkbox_siyah_mod" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <!-- Dış çember -->
                        <Ellipse Width="30" Height="30" Stroke="White" StrokeThickness="2" Fill="Black"/>
                        <!-- Onay işareti -->
                        <Path x:Name="CheckMark" Data="M 10,22 L 14,26 L 20,15"
                        Margin="0,-5,0,0"
                        Stroke="White" StrokeThickness="3"
                        StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- CheckBox işaretliyken onay işaretini göster -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="checkbox_siyah_aynalama" TargetType="CheckBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <!-- Dış çember -->
                        <Ellipse Width="30" Height="30" Stroke="White" StrokeThickness="2" Fill="Black"/>
                        <!-- Onay işareti -->
                        <Path x:Name="CheckMark" Data="M 10,22 L 14,26 L 20,15"
                     Margin="0,-5,0,0"
                     Stroke="White" StrokeThickness="3"
                     StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- CheckBox işaretliyken onay işaretini göster -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!--Yeşil Button-->
    <Style x:Key="button_template_green" TargetType="Button" >


        <Setter Property="FontFamily" Value="Roboto"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="Width" Value="75"/>
        <Setter Property="Margin" Value="0,0,0,0"/>
        <Setter Property="FontFamily" Value="Roboto"/>
        <Setter Property="Height" Value="50"/>
        <Setter Property="DockPanel.Dock" Value="Bottom"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="25" BorderThickness="0" Background="{TemplateBinding Background}">
                        <ContentPresenter  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- Hover efekti için cursor değişimi -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Opacity" Value="0.9" />
                <!-- Hover arka planı (isteğe bağlı) -->
            </Trigger>

        </Style.Triggers>

    </Style>
    <!-- Button Background Brush -->
    <RadialGradientBrush x:Key="button_background_green" 
                         RadiusX="0.55" 
                         RadiusY="5"
                         GradientOrigin="0.5,0.5" 
                         Center="0.5,0.5">
        <GradientStop Color="#0c9f04" Offset="0"/>
        <GradientStop Color="#25e432" Offset="1.1"/>
    </RadialGradientBrush>
    <!--Yeşil Button bitiş-->

