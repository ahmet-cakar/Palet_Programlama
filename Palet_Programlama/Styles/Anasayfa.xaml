<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">


    <Style x:Key="button_template" TargetType="Button" >
        <Setter Property="FontFamily" Value="Montserrat"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontSize" Value="18"/>

        <Setter Property="Width" Value="100"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Margin" Value="5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border CornerRadius="15" BorderThickness="0" Background="{TemplateBinding Background}">
                        <ContentPresenter  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        
    </Style>
    <!-- Button Background Brush -->
    <RadialGradientBrush x:Key="button_background" RadiusX="0.55" RadiusY="3" GradientOrigin="0.5,0.5" Center="0.5,0.5">
        <GradientStop Color="#FFFFBC09" Offset="0"/>
        <GradientStop Color="#FFFFDA33" Offset="0.31"/>
    </RadialGradientBrush>

</ResourceDictionary>