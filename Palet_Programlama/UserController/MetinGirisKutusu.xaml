<Window x:Class="Palet_Programlama.UserController.MetinGirisKutusu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Height="260"
        Width="500"
        Background="Transparent">

  <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
    <Border Background="#191919"
                BorderBrush="#f59f05"
                BorderThickness="2"
                CornerRadius="15"
                Padding="20">

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtBaslik"
                           Text="Bilgi Girişi"
                           FontSize="24"
                           FontFamily="Roboto"
                           Foreground="White"
                           Margin="0,0,0,15"/>

        <TextBlock x:Name="txtMesaj"
                           Grid.Row="1"
                           Text="Lütfen bir değer giriniz."
                           FontSize="16"
                           Foreground="#D0D0D0"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12"/>

        <TextBox x:Name="txtGiris"
                         Grid.Row="2"
                         Height="60"
                         FontSize="22"
                         Padding="10"
                         Background="#2A2A2A"
                         Foreground="White"
                         BorderBrush="#f59f05"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,20"/>

        <StackPanel Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            Margin="0,20,0,0">

          <Button x:Name="btnTamam"
            Content="Tamam"
            Width="150"
            Height="40"
            Margin="0,0,20,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource button_background}"
            Style="{StaticResource button_template}"
            Click="btnTamam_Click"/>

          <Button x:Name="btnIptal"
            Content="İptal"
            Width="150"
            Height="40"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="{StaticResource button_background}"
            Style="{StaticResource button_template}"
            Click="btnIptal_Click"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>