<Window x:Class="Palet_Programlama.UserController.UrunPaletSecimKutusu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:sınıflar="clr-namespace:Palet_Programlama.Sınıflar"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Height="500"
        Width="800"
        Background="Transparent">

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/Stiller/Combomax_style.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid MouseLeftButtonDown="Grid_MouseLeftButtonDown">
    <Border Background="#191919"
                BorderBrush="#f59f05"
                BorderThickness="2"
                CornerRadius="15"
                Padding="15">

      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ürün,Palet ve Dizilim seçin"
                           FontSize="22"
                           FontFamily="Roboto"
                           Margin="15"
                           Foreground="White"/>

        <Border Grid.Row="1"
                        Margin="15,10,15,10"
                        Background="#252525"
                        CornerRadius="10"
                        Padding="20">

          <StackPanel>
            <!-- Ürünler -->
            <!-- Dizilimler -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <TextBlock Text="Ürünler"
                Foreground="White"
                FontSize="20"
                VerticalAlignment="Center"/>

                          <TextBlock Text=" ( * Zorunlu)"
                Foreground="#A0A0A0"
                FontSize="12"
                Margin="8,4,0,0"
                VerticalAlignment="Center"/>
            </StackPanel>

            <ComboBox x:Name="urunComboBox"
                                  Style="{StaticResource KoyuTemaComboBox}"
                                  Height="40"
                                  FontSize="18"
                                  Text="Ürün Seçiniz"
                                  IsEditable="True"
                                  IsReadOnly="True"
                                  Margin="0,0,0,20"
                                  SelectionChanged="urunComboBox_SelectionChanged"/>

            <!-- Paletler -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <TextBlock Text="Paletler"
                Foreground="White"
                FontSize="20"
                VerticalAlignment="Center"/>

              <TextBlock Text=" ( * Zorunlu)"
                Foreground="#A0A0A0"
                FontSize="12"
                Margin="8,4,0,0"
                VerticalAlignment="Center"/>
            </StackPanel>


            <ComboBox x:Name="paletComboBox"
                                  Style="{StaticResource KoyuTemaComboBox}"
                                  Height="40"
                                  FontSize="18"
                                  Text="Palet Seçiniz"
                                  IsEditable="True"
                                  IsReadOnly="True"
                                  Margin="0,0,0,20"
                                  SelectionChanged="paletComboBox_SelectionChanged"/>

            <!-- Dizilimler -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <TextBlock Text="Dizilimler"
               Foreground="White"
               FontSize="20"
               VerticalAlignment="Center"/>

              <TextBlock x:Name="txtDizilimAciklama" Text=" (Dizilim güncellemek için seçebilirsiniz.)"
               Foreground="#A0A0A0"
               FontSize="12"
               Margin="8,4,0,0"
               VerticalAlignment="Center"/>
            </StackPanel>

            <ComboBox x:Name="dizilimComboBox"
                                  Style="{StaticResource KoyuTemaComboBox}"
                                  Height="40"
                                  SelectionChanged="dizilimComboBox_SelectionChanged"
                                  FontSize="18"
                                  Text="Dizilim Seçiniz"
                                  IsEditable="True"
                                  IsReadOnly="True"/>
          </StackPanel>
        </Border>

        <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
          <Button x:Name="btnTamam"
                            Content="Tamam"
                            Width="150"
                            Height="40"
                            Margin="0,0,15,0"
                            Background="{StaticResource button_background}"
                            Style="{StaticResource button_template}"
                            Click="btnTamam_Click"/>

          <Button x:Name="btnIptal"
                            Content="İptal"
                            Width="150"
                            Height="40"
                            Background="{StaticResource button_background}"
                            Style="{StaticResource button_template}"
                            Click="btnIptal_Click"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>